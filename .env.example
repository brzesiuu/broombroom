# BroomBroom configuration — copy to .env and fill in values

# ── Cache ──────────────────────────────────────────────────────────────────────
BB_CACHE_DIR=data/cache
BB_FASTF1_CACHE_DIR=data/cache/fastf1
BB_APP_CACHE_DIR=data/cache/app

# ── Logging ────────────────────────────────────────────────────────────────────
# "pretty" for local dev, "json" for CI / structured logging
BB_LOG_FORMAT=pretty
BB_LOG_LEVEL=INFO

# ── API behaviour ──────────────────────────────────────────────────────────────
BB_JOLPICA_BASE_URL=https://api.jolpi.ca/ergast
BB_OPENF1_BASE_URL=https://api.openf1.org/v1
BB_OPENF1_RATE_LIMIT_PER_SECOND=3
BB_JOLPICA_RATE_LIMIT_PER_SECOND=1
BB_HTTP_TIMEOUT_SECONDS=30
BB_HTTP_MAX_RETRIES=3

# ── Feature flags ──────────────────────────────────────────────────────────────
BB_ENABLE_OPENF1=true
BB_ENABLE_REALTIME=false

# ── ML / Experiment tracking ───────────────────────────────────────────────────
BB_MODEL_DIR=data/models
BB_MLFLOW_TRACKING_URI=data/mlflow
BB_PREDICTION_MIN_YEAR=2018
